# .env (This file should be at the project root, same level as docker-compose.yml)

# Django settings
DEBUG=True
DJANGO_SETTINGS_MODULE=ai_marketplace.settings
DJANGO_SECRET_KEY='django-insecure-(temporary-dev-key)-g$s&s!f#j@q9z*p%l@w*n&c#x@v' # Replace with a real secret key if deploying beyond local dev
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1] backend frontend # 'backend' for Nginx to Django, 'frontend' if backend needs to call frontend by service name

# PostgreSQL Settings (used by docker-compose to set env for 'db' service and by Django via DATABASE_URL)
DB_ENGINE=django.db.backends.postgresql # Informational, DATABASE_URL is primary
DB_NAME=marketplace
DB_USER=admin
DB_PASS=admin
DB_HOST=db # This is the service name of the PostgreSQL container in docker-compose.yml
DB_PORT=5432 # Default PostgreSQL port

# DATABASE_URL for django-environ (used by Django app)
# This format is for django-environ to parse. Docker-compose's `backend` service uses this.
DATABASE_URL=postgresql://admin:admin@db:5432/marketplace

# React App settings (example, not directly used by Nginx unless Nginx config is processed by envsubst)
# REACT_APP_API_BASE_URL=/api

# Nginx proxy pass target (example if Nginx config was to be templated, not used by current setup)
# NGINX_API_PROXY_PASS=http://backend:8000
